# =========================================================
# 🎬 Movie Recommendation System — Environment Variables
# Copy this file to .env and fill in your actual values
# =========================================================

# ---- General ----
NODE_ENV=development
PORT=5000

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/movie_recommendation
# For Docker:
# MONGO_URI=mongodb://mongo:27017/movie_recommendation

# ---- Redis ----
REDIS_URL=redis://localhost:6379
# For Docker:
# REDIS_URL=redis://redis:6379

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- TMDB API (https://www.themoviedb.org/settings/api) ----
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ---- OpenAI API (https://platform.openai.com/api-keys) ----
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ---- YouTube Data API v3 (https://console.developers.google.com/) ----
YOUTUBE_API_KEY=your_youtube_api_key_here

# ---- Streaming Availability API (https://rapidapi.com/movie-of-the-night-movie-of-the-night-default/api/streaming-availability) ----
STREAMING_API_KEY=your_rapidapi_key_here
STREAMING_API_HOST=streaming-availability.p.rapidapi.com

# ---- Python ML Service ----
ML_SERVICE_URL=http://localhost:8000
# For Docker:
# ML_SERVICE_URL=http://ml-service:8000

# ---- Frontend (for Vite) ----
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_ML_SERVICE_URL=http://localhost:8000

# ---- Admin ----
ADMIN_EMAIL=admin@movieai.com
ADMIN_PASSWORD=Admin@123
